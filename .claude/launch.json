{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "noxioai-static",
      "runtimeExecutable": "python3",
      "runtimeArgs": [
        "-m",
        "http.server",
        "4173",
        "--directory",
        ".output/public"
      ],
      "port": 4173
    },
    {
      "name": "noxioai-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--no-fork"
      ],
      "port": 3000
    }
  ]
}