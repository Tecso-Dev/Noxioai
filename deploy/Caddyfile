(appapi) {
	# ONLY the genuinely-public app endpoints reach the backend.
	@public path /api/auth/* /api/billing/* /api/stripe/* /api/waitlist
	handle @public {
		reverse_proxy 127.0.0.1:7700
	}
	# HUD, agent controls (/api/send /atlas /oracle /brief /inbox /pixel /approve),
	# /chat, /api/status, /api/agent, static HUD assets → blocked from the internet.
	handle {
		respond "404" 404
	}
}

api.noxioai.com {
	import appapi
}

